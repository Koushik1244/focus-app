generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id         String    @id @default(cuid())
  wallet     String
  duration   Int
  stake      Float
  focusScore Float?
  success    Boolean?
  reward     Float?
  createdAt  DateTime  @default(now())
  settledAt  DateTime?
}
